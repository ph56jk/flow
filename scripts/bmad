#!/bin/zsh
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
NODE_BIN="$ROOT_DIR/.local/node/bin"

if [ ! -x "$NODE_BIN/node" ]; then
  echo "Khong tim thay Node cuc bo trong du an. Hay cai lai BMAD hoac Node truoc." >&2
  exit 1
fi

export PATH="$NODE_BIN:$PATH"
exec "$NODE_BIN/npx" bmad-method "$@"
